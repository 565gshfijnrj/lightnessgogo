window.addRest = async function(){
    const date = getCurrentDate(); if(!date){ alert("請選日期"); return; }
    const room = document.getElementById("restRoom").value;
    const name = document.getElementById("restName").value;
    if(!name || !room){ alert("請填寫房號與姓名"); return; }

    const btn = document.getElementById("btnSaveRest");
    btn.innerText = "處理中..."; btn.disabled = true;

    let st = document.getElementById("restStartTime").value;
    let et = document.getElementById("restEndTime").value;
    let combinedTime = (st || et) ? `${st}~${et}` : "";

    let existingData = currentRestIndex >= 0 ? restData[date][currentRestIndex] : {};
    
    let restObj = { 
        room: room, name: name, phone: document.getElementById("restPhone").value, 
        people: String(Number(document.getElementById("restPeople").value) || 2), 
        time: combinedTime, price: String(Number(document.getElementById("restPrice").value) || 0), 
        id: document.getElementById("restID").value, note: document.getElementById("restNote").value, 
        status: (currentRestIndex >= 0 && existingData) ? existingData.status : "resting"
    };

    let changes = {};
    let hasChanges = false;
    Object.keys(restFieldMap).forEach(key => {
        let oldVal = String(existingData[key] || "");
        let newVal = String(restObj[key] || "");
        if (oldVal !== newVal && Object.keys(existingData).length > 0) { 
            changes[key] = { old: oldVal, new: newVal };
            hasChanges = true;
        }
    });

    let logs = existingData.updateLogs ? [...existingData.updateLogs] : [];
    if (hasChanges) {
        let snapshotData = { ...restObj };
        delete snapshotData.updateLogs; 
        logs.push({ timestamp: getLogTimestamp(), changes: changes, snapshot: snapshotData });
    }
    restObj.updateLogs = logs;

    if(!restData[date]){ restData[date]=[]; }
    
    if (currentRestIndex >= 0) { restData[date][currentRestIndex] = restObj; } 
    else { restData[date].push(restObj); }
    
    try { 
        await setDoc(doc(db, "restData", date), { data: restData[date] }); 
        updateUI(); closeModalRest();
    } catch(e) { alert("儲存失敗"); } finally { btn.innerText = "確認建立"; btn.disabled = false; }
}

window.checkoutRestAction = async function() {
    if (currentRestIndex >= 0) {
        const date = getCurrentDate();
        let currentData = restData[date][currentRestIndex];
        let logs = currentData.updateLogs ? [...currentData.updateLogs] : [];
        
        if(currentData.status === "resting") {
            if (confirm("確定要「結束休息」嗎？")) {
                let snapshotData = { ...currentData, status: "checkout" };
                delete snapshotData.updateLogs;
                logs.push({ timestamp: getLogTimestamp(), changes: { status: { old: "resting", new: "checkout" } }, snapshot: snapshotData });
                restData[date][currentRestIndex].status = "checkout";
                restData[date][currentRestIndex].updateLogs = logs;
                await setDoc(doc(db, "restData", date), { data: restData[date] }); 
                updateUI(); closeModalRest();
            }
        } else {
            if (confirm("此房已結束。\n是否要「恢復為休息中」(誤觸恢復)？")) {
                let snapshotData = { ...currentData, status: "resting" };
                delete snapshotData.updateLogs;
                logs.push({ timestamp: getLogTimestamp(), changes: { status: { old: "checkout", new: "resting" } }, snapshot: snapshotData });
                restData[date][currentRestIndex].status = "resting";
                restData[date][currentRestIndex].updateLogs = logs;
                await setDoc(doc(db, "restData", date), { data: restData[date] }); 
                updateUI(); closeModalRest();
            }
        }
    }
}

window.deleteRestAction = async function() {
    if (currentRestIndex >= 0 && confirm("確定要刪除這筆休息資料嗎？")) {
        const date = getCurrentDate();
        restData[date].splice(currentRestIndex, 1);
        await setDoc(doc(db, "restData", date), { data: restData[date] }); 
        updateUI(); closeModalRest();
    }
}
window.saveRestAction = window.addRest;

async function loadData() {
    const date = document.getElementById("selectedDate").value; 
    try { const docSnap = await getDoc(doc(db, "bookings", date)); bookings[date] = docSnap.exists() ? docSnap.data() : {}; } catch(e) { bookings[date] = {}; }
}
async function loadRestData() {
    const date = document.getElementById("selectedDate").value;
    try { const docSnap = await getDoc(doc(db, "restData", date)); restData[date] = docSnap.exists() ? docSnap.data().data || [] : []; } catch(e) { restData[date] = []; }
}

function updateStats() {
    const date = document.getElementById("selectedDate").value; const statsBox = document.getElementById("statsBox");
    if (!date) { statsBox.innerHTML = "<div style='text-align:center;'>資料載入中...</div>"; return; }

    let dailyTotalPeople = 0, currentInHousePeople = 0;  
    let countryStats = {}; 

    if (bookings[date]) { 
        Object.values(bookings[date]).forEach(data => { 
            let p = Number(data.people) || 0; 
            let c = data.country || "台灣";
            if (!countryStats[c]) countryStats[c] = { daily: 0, inHouse: 0 };

            if (data.everCheckedIn) {
                dailyTotalPeople += p; 
                countryStats[c].daily += p;
            }
            if (data.status === 'checkedin') {
                currentInHousePeople += p; 
                countryStats[c].inHouse += p;
            }
        }); 
    }

    let dailyHtml = `<b>當日人數 (${dailyTotalPeople})</b><div style="margin-top:4px; font-size:12px; display:flex; flex-direction:column; gap:2px;">`;
    let inHouseHtml = `<b>住宿在店人數 (${currentInHousePeople})</b><div style="margin-top:4px; font-size:12px; display:flex; flex-direction:column; gap:2px;">`;
    
    let hasDaily = false; let hasInHouse = false;
    for (let c in countryStats) {
        if (countryStats[c].daily > 0) { dailyHtml += `<div>${c}：${countryStats[c].daily} 位</div>`; hasDaily = true; }
        if (countryStats[c].inHouse > 0) { inHouseHtml += `<div>${c}：${countryStats[c].inHouse} 位</div>`; hasInHouse = true; }
    }
    if (!hasDaily) dailyHtml += `<div style="color:var(--text-muted)">無資料</div>`;
    if (!hasInHouse) inHouseHtml += `<div style="color:var(--text-muted)">無資料</div>`;
    
    dailyHtml += `</div>`; inHouseHtml += `</div>`;

    statsBox.innerHTML = `<div style="display:flex; justify-content:space-around; width:100%; text-align:left; gap:10px;">
        <div class="stats-col">${dailyHtml}</div>
        <div class="stats-divider"></div>
        <div class="stats-col">${inHouseHtml}</div>
    </div>`;
}

function updateRestRoomOptions(prefillRoom = "") {
    const date = document.getElementById("selectedDate").value; const restRoomSelect = document.getElementById("restRoom"); const currentBookings = bookings[date] || {};
    restRoomSelect.innerHTML = '<option value="">選擇房號</option>';
    rooms.forEach(room => { 
        if (!currentBookings[room] || currentBookings[room].status !== 'checkedin' || currentBookings[room].status === 'checkedout' || room === prefillRoom) { 
            const op = document.createElement("option"); op.value = room; op.textContent = room; 
            if (currentRoom === "" && currentBookings[room] && currentBookings[room].status !== 'checkedout') {
                op.disabled = true; op.textContent = room + " (已佔用)";
            }
            restRoomSelect.appendChild(op); 
        } 
    });
}
