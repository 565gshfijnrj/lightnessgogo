            orderDate: document.getElementById("orderDate").value || "", 
            people: document.getElementById("people").value || "", 
            total: document.getElementById("total").value || "",
            deposit: document.getElementById("deposit").value || "", 
            balance: document.getElementById("balance").value || "",
            country: document.getElementById("country").value || "", 
            platform: document.getElementById("platform").value || "",
            request: document.getElementById("request").value || "", 
            payStatus: document.getElementById("payStatus").value || "",
            checkinDate: checkin, 
            checkoutDate: checkout,
            everCheckedIn: false 
        };

        const selectedDate = document.getElementById("selectedDate").value;
        const existingData = bookings[selectedDate]?.[currentRoom] || {};
        
        let changes = {};
        let hasChanges = false;
        Object.keys(bookingFieldMap).forEach(key => {
            let oldVal = String(existingData[key] || "");
            let newVal = String(orderData[key] || "");
            if (oldVal !== newVal && Object.keys(existingData).length > 0) { 
                changes[key] = { old: oldVal, new: newVal };
                hasChanges = true;
            }
        });

        // ⭐ 修復 Maximum call stack size exceeded
        let logs = existingData.updateLogs ? [...existingData.updateLogs] : [];
        if (hasChanges) {
            let snapshotData = { ...orderData };
            delete snapshotData.updateLogs; // 絕不能把 Logs 存進快照裡
            logs.push({ timestamp: getLogTimestamp(), changes: changes, snapshot: snapshotData });
        }
        orderData.updateLogs = logs;

        if (existingData.checkinDate && existingData.checkoutDate) {
            orderData.status = existingData.status;
            orderData.everCheckedIn = existingData.everCheckedIn || false;

            if (existingData.checkinDate !== checkin || existingData.checkoutDate !== checkout) {
                let [ocy, ocm, ocd] = existingData.checkinDate.split("-"); let oldCurr = new Date(ocy, ocm-1, ocd);
                let [oey, oem, oed] = existingData.checkoutDate.split("-"); const oldEnd = new Date(oey, oem-1, oed);
                while(oldCurr < oldEnd){
                    const odStr = getDateString(oldCurr);
                    if(bookings[odStr] && bookings[odStr][currentRoom]) {
                        delete bookings[odStr][currentRoom];
                        await setDoc(doc(db, "bookings", odStr), bookings[odStr]);
                    }
                    oldCurr.setDate(oldCurr.getDate() + 1);
                }
            }
        } else {
            orderData.status = "booked";
        }

        let dayIndex = 0;
        let writeCurrent = new Date(cy, cm-1, cd);
        while(writeCurrent < end){
            const dateStr = getDateString(writeCurrent);
            if(!bookings[dateStr]) bookings[dateStr] = {};
            
            bookings[dateStr][currentRoom] = { ...orderData, status: dayIndex === 0 ? (orderData.status || "booked") : "stay" };
            await setDoc(doc(db, "bookings", dateStr), bookings[dateStr]);
            writeCurrent.setDate(writeCurrent.getDate() + 1); 
            dayIndex++;
        }

        saveBtn.innerHTML = "💾 儲存"; saveBtn.disabled = false;
        updateUI(); closeModal();
    } catch(err) {
        alert("儲存失敗: " + err.message);
        document.getElementById("btnSaveBooking").innerHTML = "💾 儲存"; 
        document.getElementById("btnSaveBooking").disabled = false;
    }
}

window.setStatus = async function(status){
    try {
        const date = document.getElementById("selectedDate").value; const data = bookings[date]?.[currentRoom];
        if(!data) return;
        
        let logs = data.updateLogs ? [...data.updateLogs] : [];
        let snapshotData = { ...data, status: status };
        delete snapshotData.updateLogs; // 防護機制

        logs.push({
            timestamp: getLogTimestamp(),
            changes: { status: { old: data.status, new: status } },
            snapshot: snapshotData
        });

        let [cy, cm, cd] = (data.checkinDate || date).split("-"); let current = new Date(cy, cm-1, cd);
        let [ey, em, ed] = (data.checkoutDate || date).split("-"); const checkout = new Date(ey, em-1, ed);

        if (current < checkout) {
            while(current < checkout){
                const dStr = getDateString(current);
                if(bookings[dStr]?.[currentRoom]){
                    bookings[dStr][currentRoom].status = status;
                    bookings[dStr][currentRoom].updateLogs = logs;
                    if(status === "checkedin" || status === "checkedout") bookings[dStr][currentRoom].everCheckedIn = true;
                    await setDoc(doc(db, "bookings", dStr), bookings[dStr]);
                }
                current.setDate(current.getDate() + 1);
            }
        } else {
            bookings[date][currentRoom].status = status;
            bookings[date][currentRoom].updateLogs = logs;
            if(status === "checkedin" || status === "checkedout") bookings[date][currentRoom].everCheckedIn = true;
            await setDoc(doc(db, "bookings", date), bookings[date]);
        }
        updateUI(); closeModal();
    } catch (e) {
        alert("變更狀態失敗，請檢查資料庫連線");
    }
}

window.deleteBooking = async function(){
    const date = document.getElementById("selectedDate").value; const data = bookings[date]?.[currentRoom];
    if(!data) return;
    if(confirm("確定取消訂單？ (連續日期的訂單將連帶刪除)")){
        if (data.checkinDate && data.checkoutDate) {
            let [cy, cm, cd] = data.checkinDate.split("-"); let current = new Date(cy, cm-1, cd);
            let [ey, em, ed] = data.checkoutDate.split("-"); const end = new Date(ey, em-1, ed);
            while(current < end){
                const dStr = getDateString(current);
                if(bookings[dStr]){ delete bookings[dStr][currentRoom]; await setDoc(doc(db, "bookings", dStr), bookings[dStr]); }
                current.setDate(current.getDate() + 1);
            }
        } else {
            delete bookings[date][currentRoom]; 
            await setDoc(doc(db, "bookings", date), bookings[date]);
        }
        updateUI(); closeModal();
    }
}

