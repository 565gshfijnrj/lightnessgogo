                let statusName = activeRest.status === "resting" ? "休息中" : "已結束";
                let badgeClass = activeRest.status === "resting" ? "badge-resting" : "badge-checkedout";
                
                html += `<span class="status-badge ${badgeClass}">${statusName}</span></div>`;
                html += `<div class="guest-name-row">${activeRest.name}</div>`;
                
                // ⭐ 雙欄位排版
                html += `<div class="detail-grid-split">`;
                html += `<div class="detail-col">`;
                html += `<div class="detail-item"><b>聯絡電話</b><span>${activeRest.phone || '-'}</span></div>`;
                html += `<div class="detail-item"><b>證件號碼</b><span>${activeRest.id || '-'}</span></div>`;
