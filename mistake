function calcBalance() {
    const totalEl = document.getElementById("total");
    const depositEl = document.getElementById("deposit");
    const balanceEl = document.getElementById("balance");
    const payStatusEl = document.getElementById("payStatus");
    
    if (totalEl && depositEl && balanceEl && payStatusEl) {
        if (payStatusEl.value === 'paid' || payStatusEl.value === 'platform') {
            balanceEl.value = 0;
        } else {
            balanceEl.value = (Number(totalEl.value) || 0) - (Number(depositEl.value) || 0);
        }
    }
}

