function getLogTimestamp() {
    const now = new Date();
    const y = now.getFullYear();
    const m = String(now.getMonth() + 1).padStart(2, '0');
    const d = String(now.getDate()).padStart(2, '0');
    const h = now.getHours();
    const ampm = h >= 12 ? '下午' : '上午';
    const hh = String(h > 12 ? h - 12 : (h === 0 ? 12 : h)).padStart(2, '0');
    const mm = String(now.getMinutes()).padStart(2, '0');
    const ss = String(now.getSeconds()).padStart(2, '0');
    return `${y}/${m}/${d} ${ampm} ${hh}:${mm} ${ss}秒 修改`;
}

window.toggleLogDetails = function(element) {
    const details = element.nextElementSibling;
    const icon = element.querySelector('.expand-icon');
    details.classList.toggle('show');
    icon.classList.toggle('open');
}

function renderLogs(elementId, logsArray, fieldMap) {
    const container = document.getElementById(elementId);
    if (!logsArray || logsArray.length === 0) {
        container.innerHTML = '<div class="log-empty">尚無修改紀錄</div>';
        return;
    }
    
    let html = '';
    const formatVal = (v, k) => {
        if(v === "" || v === undefined) return "-";
        if(k === 'payStatus') return v === 'paid' ? '現場已結清' : v === 'platform' ? '平台已收' : '未付清';
        if(k === 'status') return v === 'checkedin' ? '入住中' : v === 'checkedout' ? '已退房' : v === 'stay' ? '續住' : v === 'booked' ? '已預訂' : v === 'resting' ? '休息中' : v === 'checkout' ? '結束休息' : v;
        if(k === 'people') return v + "位";
        return v;
    };

    for (let i = logsArray.length - 1; i >= 0; i--) {
        let log = logsArray[i];
        if (typeof log === 'string') {
            html += `<div class="log-item"><div class="log-header" style="cursor:default;"><span>✏️ ${log}</span></div></div>`;
        } else {
            let detailsHtml = '';
            for (let key in fieldMap) {
                let label = fieldMap[key];
                let isChanged = log.changes && log.changes[key] !== undefined;
                let currentVal = log.snapshot ? log.snapshot[key] : '-';
                
                if (isChanged) {
                    let oldVal = formatVal(log.changes[key].old, key);
                    let newVal = formatVal(log.changes[key].new, key);
                    detailsHtml += `<div class="log-row log-changed"><b>${label}</b><span>${oldVal} ➔ <strong>${newVal}</strong></span></div>`;
                } else {
                    detailsHtml += `<div class="log-row log-unchanged"><b>${label}</b><span>${formatVal(currentVal, key)}</span></div>`;
                }
            }
            
            html += `
            <div class="log-item">
                <div class="log-header" onclick="toggleLogDetails(this)">
                    <span>✏️ ${log.timestamp}</span>
                    <span class="expand-icon">▼</span>
                </div>
                <div class="log-details">${detailsHtml}</div>
            </div>`;
        }
    }
    container.innerHTML = html;
}

