let touchstartX = 0, touchendX = 0, touchstartY = 0, touchendY = 0;
const container = document.getElementById('mainContainer');
container.addEventListener('touchstart', e => { touchstartX = e.changedTouches[0].screenX; touchstartY = e.changedTouches[0].screenY; }, {passive: true});
container.addEventListener('touchend', e => { touchendX = e.changedTouches[0].screenX; touchendY = e.changedTouches[0].screenY; handleSwipe(); }, {passive: true});

function handleSwipe() {
    const thresholdX = 120; 
    const thresholdY = 40;  
    let diffX = touchendX - touchstartX;
    let diffY = Math.abs(touchendY - touchstartY);
    
    if (diffY < thresholdY) {
        if (diffX < -thresholdX) window.changeDate(1); 
        else if (diffX > thresholdX) window.changeDate(-1); 
    }
}

window.searchGuest = async function() {
    const keyword = document.getElementById("searchInput").value.trim().toLowerCase();
    if(!keyword) { alert("請輸入關鍵字"); return; }

    document.getElementById("modalOverlaySearch").style.display = "block";
    document.getElementById("searchModal").style.display = "flex";
    document.body.classList.add("no-scroll");
    
    const tbody = document.getElementById("searchResultsBody");
    tbody.innerHTML = "<tr><td colspan='5' style='text-align:center; padding: 30px;'>🔄 搜尋中...</td></tr>";

    let results = []; let seenBookings = new Set(); 

    try {
        const bookingsSnap = await getDocs(collection(db, "bookings"));
        bookingsSnap.forEach(docSnap => {
            const dailyData = docSnap.data();
            for (let room in dailyData) {
                let b = dailyData[room];
                if ((b.name && String(b.name).toLowerCase().includes(keyword)) || (b.phone && String(b.phone).toLowerCase().includes(keyword))) {
                    let uniqueKey = `booking_${room}_${b.checkinDate}_${b.name}`;
                    if (!seenBookings.has(uniqueKey)) {
                        seenBookings.add(uniqueKey);
                        results.push({ type: '住宿', room: room, date: `${b.checkinDate} ~ ${b.checkoutDate}`, name: b.name||'-', platform: b.platform||'-', payStatus: b.payStatus, balance: b.balance, sortDate: new Date(b.checkinDate) });
                    }
                }
            }
        });

        const restsSnap = await getDocs(collection(db, "restData"));
        restsSnap.forEach(docSnap => {
            const dateStr = docSnap.id;
            (docSnap.data().data || []).forEach(r => {
                if ((r.name && String(r.name).toLowerCase().includes(keyword)) || (r.phone && String(r.phone).toLowerCase().includes(keyword))) {
                    results.push({ type: '休息', room: r.room, date: `${dateStr} (${r.time||'-'})`, name: r.name||'-', platform: '現場', payStatus: 'paid', price: r.price, sortDate: new Date(dateStr) });
                }
            });
        });

        results.sort((a, b) => b.sortDate - a.sortDate);

        if (results.length === 0) {
            tbody.innerHTML = "<tr><td colspan='5' style='text-align:center; padding: 30px; color:var(--text-muted);'>查無資料</td></tr>";
        } else {
            tbody.innerHTML = results.map(r => {
                let payBadge = "";
                if(r.type === '住宿') {
                    if (r.payStatus === 'paid') payBadge = '<span style="color:#10b981; font-weight:bold;">已結清</span>';
                    else if (r.payStatus === 'platform') payBadge = '<span style="color:#3b82f6; font-weight:bold;">平台付</span>';
                    else payBadge = `<span style="color:#ef4444; font-weight:bold;">欠款 $${r.balance || 0}</span>`;
                } else {
                    payBadge = `<span style="color:#10b981; font-weight:bold;">已結清 ($${r.price || 0})</span>`;
                }
                return `<tr>
                    <td><span style="font-size:12px; font-weight:bold; color:${r.type==='住宿'?'#b45309':'#1d4ed8'};">${r.type}</span></td>
                    <td><b>${r.name}</b><br><small style="color:var(--text-muted);">房號: ${r.room}</small></td>
                    <td>${r.date}</td><td>${r.platform}</td><td>${payBadge}</td>
                </tr>`;
            }).join("");
        }
    } catch (e) { tbody.innerHTML = "<tr><td colspan='5' style='text-align:center; color:red; padding: 30px;'>系統錯誤</td></tr>"; }
}

